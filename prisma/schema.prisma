generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
}

enum IssueType {
  BUG
  TASK
  STORY
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
}

enum IssueStatus {
  TODO
  IN_PROGRESS
  CODE_REVIEW
  DONE
}

enum ReleaseStatus {
  UNRELEASED
  RELEASED
}

model ConfirmEmailToken {
  userId Int    @id
  token  String @unique
  User   User   @relation(fields: [userId], references: [id])
}

model PasswordRecoveryToken {
  userId Int    @id
  token  String @unique
  User   User   @relation(fields: [userId], references: [id])
}

model User {
  id                    Int                    @id @default(autoincrement())
  email                 String                 @unique
  name                  String
  avatarUrl             String?
  createdAt             DateTime               @default(now()) @db.Timestamptz(6)
  password              String
  verified              Boolean                @default(false)
  ConfirmEmailToken     ConfirmEmailToken?
  PasswordRecoveryToken PasswordRecoveryToken?
  ownedProjects         Project[]              @relation("ProjectOwner")
  projectMemberships    ProjectMember[]
  assignedIssues        Issue[]                @relation("IssueAssignee")
  reportedIssues        Issue[]                @relation("IssueReporter")
  initiatedReleases     Release[]              @relation("ReleaseInitiator")
  issueComments         IssueComment[]
}

model Project {
  id          Int             @id @default(autoincrement())
  key         String          @unique
  name        String
  description String?
  ownerId     Int
  createdAt   DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @db.Timestamptz(6)
  owner       User            @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  sprints     Sprint[]
  issues      Issue[]
  releases    Release[]
}

model ProjectMember {
  id        Int         @id @default(autoincrement())
  projectId Int
  userId    Int
  role      ProjectRole @default(MEMBER)
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  project   Project     @relation(fields: [projectId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId, role])
}

model Sprint {
  id        Int      @id @default(autoincrement())
  projectId Int
  name      String
  startDate DateTime @db.Timestamptz(6)
  endDate   DateTime @db.Timestamptz(6)
  goal      String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  project   Project  @relation(fields: [projectId], references: [id])
  issues    Issue[]

  @@index([projectId, isActive])
  @@index([projectId, startDate])
}

model Issue {
  id          Int           @id @default(autoincrement())
  projectId   Int
  title       String
  description String?
  type        IssueType
  priority    IssuePriority
  status      IssueStatus   @default(TODO)
  storyPoints Int?
  assigneeId  Int?
  reporterId  Int
  sprintId    Int?
  releaseId   Int?
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(6)
  project     Project       @relation(fields: [projectId], references: [id])
  assignee    User?         @relation("IssueAssignee", fields: [assigneeId], references: [id])
  reporter    User          @relation("IssueReporter", fields: [reporterId], references: [id])
  sprint      Sprint?       @relation(fields: [sprintId], references: [id])
  release     Release?      @relation(fields: [releaseId], references: [id])
  comments    IssueComment[]

  @@index([projectId, sprintId])
  @@index([projectId, releaseId])
  @@index([projectId, status])
  @@index([projectId, priority])
}

model IssueComment {
  id        Int      @id @default(autoincrement())
  issueId    Int
  authorId   Int
  content    String
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)
  issue      Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author     User      @relation(fields: [authorId], references: [id])

  @@index([issueId, createdAt])
  @@index([authorId])
}

model Release {
  id          Int           @id @default(autoincrement())
  projectId   Int
  initiatorId Int
  name        String
  description String?
  startDate   DateTime      @db.Timestamptz(6)
  releaseDate DateTime      @db.Timestamptz(6)
  status      ReleaseStatus @default(UNRELEASED)
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(6)
  project     Project       @relation(fields: [projectId], references: [id])
  initiator   User          @relation("ReleaseInitiator", fields: [initiatorId], references: [id])
  issues      Issue[]

  @@index([projectId, status])
  @@index([projectId, releaseDate])
}
